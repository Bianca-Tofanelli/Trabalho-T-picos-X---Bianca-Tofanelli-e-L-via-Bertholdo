generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          Int          @id @default(autoincrement())
  name        String
  email       String       @unique
  password    String
  
  // No SQLite, trocamos o Enum por String com um valor padrão entre aspas
  role        String       @default("ALUNO") 
  
  quizzes     Quiz[]
  questions   Question[]
  
  // 👇 ADICIONADO: O Prisma precisa saber que um usuário tem várias submissões
  submissions Submission[] 
}

model Quiz {
  id               Int            @id @default(autoincrement())
  title            String
  duration         Int
  startDate        DateTime
  endDate          DateTime
  
  // Trocado de Enum para String
  feedbackStrategy String         @default("AFTER_CLOSE") 
  
  professorId      Int
  professor        User           @relation(fields: [professorId], references: [id])
  
  questions        QuizQuestion[]
  
  // 👇 ADICIONADO: O Prisma precisa saber que uma prova tem várias submissões
  submissions      Submission[]   
}

model Question {
  id          Int            @id @default(autoincrement())
  content     String
  
  // Trocado de Enum para String (receberá "MULTIPLE_CHOICE", "TRUE_FALSE" ou "ESSAY")
  type        String   
  
  details     String   // Guardará as opções e respostas em formato JSON
  professorId Int
  professor   User     @relation(fields: [professorId], references: [id])
  releaseMode String   @default("IMMEDIATE") // Pode ser: IMMEDIATE, AFTER_DEADLINE, ou MANUAL
  isReleased  Boolean  @default(false)       // O "botão" para o professor liberar manualmente
  
  quizzes     QuizQuestion[]
}

// Tabela de ligação entre Quiz e Questões (Muitos para Muitos)
model QuizQuestion {
  quizId     Int
  questionId Int
  
  quiz       Quiz     @relation(fields: [quizId], references: [id])
  question   Question @relation(fields: [questionId], references: [id])

  @@id([quizId, questionId])
}

model Submission {
  id        Int      @id @default(autoincrement())
  studentId Int
  quizId    Int
  answers   String   // Guardará as respostas mapeadas como texto JSON
  score     Float?   // A nota total (pode ser null até o professor corrigir)
  status    String   @default("PENDING_REVIEW") // PENDING_REVIEW ou GRADED
  createdAt DateTime @default(now())

  // 👇 ADICIONADO: As conexões oficiais que o Prisma precisava para não quebrar 👇
  student   User     @relation(fields: [studentId], references: [id])
  quiz      Quiz     @relation(fields: [quizId], references: [id])
}