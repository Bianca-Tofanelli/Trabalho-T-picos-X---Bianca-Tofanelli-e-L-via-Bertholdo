generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  
  // No SQLite, trocamos o Enum por String com um valor padrão entre aspas
  role      String   @default("ALUNO") 
  
  quizzes   Quiz[]
  questions Question[]
}

model Quiz {
  id               Int      @id @default(autoincrement())
  title            String
  duration         Int
  startDate        DateTime
  endDate          DateTime
  
  // Trocado de Enum para String
  feedbackStrategy String   @default("AFTER_CLOSE") 
  
  professorId      Int
  professor        User     @relation(fields: [professorId], references: [id])
  
  questions        QuizQuestion[]
}

model Question {
  id          Int      @id @default(autoincrement())
  content     String
  
  // Trocado de Enum para String (receberá "MULTIPLE_CHOICE", "TRUE_FALSE" ou "ESSAY")
  type        String   
  
  details     String   // Guardará as opções e respostas em formato JSON
  professorId Int
  professor   User     @relation(fields: [professorId], references: [id])
  
  quizzes     QuizQuestion[]
}

// Tabela de ligação entre Quiz e Questões (Muitos para Muitos)
model QuizQuestion {
  quizId     Int
  questionId Int
  
  quiz       Quiz     @relation(fields: [quizId], references: [id])
  question   Question @relation(fields: [questionId], references: [id])

  @@id([quizId, questionId])
}
model Submission {
  id        Int      @id @default(autoincrement())
  studentId Int
  quizId    Int
  answers   String   // Guardará as respostas mapeadas como texto JSON
  createdAt DateTime @default(now())
}