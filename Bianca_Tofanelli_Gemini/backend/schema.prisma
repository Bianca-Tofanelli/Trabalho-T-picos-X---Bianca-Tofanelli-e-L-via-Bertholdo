// schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" // Pode ser mysql, sqlite, etc.
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// ENUMS
// -----------------------------------------------------------------------------
enum Role {
  PROFESSOR
  ALUNO
}

// -----------------------------------------------------------------------------
// MODELS
// -----------------------------------------------------------------------------

model User {
  id           String       @id @default(uuid())
  name         String
  email        String       @unique
  passwordHash String
  role         Role         @default(ALUNO)
  createdAt    DateTime     @default(now())

  // Relacionamentos
  createdQuizzes    Quiz[]       @relation("ProfessorQuizzes")
  createdQuestions  Question[]   @relation("ProfessorQuestions")
  createdRubrics    Rubric[]     @relation("ProfessorRubrics")
  submissions       Submission[] @relation("AlunoSubmissions")
}

model Rubric {
  id          String     @id @default(uuid())
  title       String
  criteria    Json       // Ex: [{"criterio": "Clareza", "peso": 2}, ...]
  createdAt   DateTime   @default(now())

  // Relacionamentos
  professorId String
  professor   User       @relation("ProfessorRubrics", fields: [professorId], references: [id])
  questions   Question[] 
}

model Question {
  id          String   @id @default(uuid())
  content     String   @db.Text
  createdAt   DateTime @default(now())

  // Relacionamentos
  professorId String
  professor   User     @relation("ProfessorQuestions", fields: [professorId], references: [id])
  rubricId    String?
  rubric      Rubric?  @relation(fields: [rubricId], references: [id])
  quizzes     QuizQuestion[] 
}

model Quiz {
  id          String         @id @default(uuid())
  title       String
  createdAt   DateTime       @default(now())

  // Relacionamentos
  professorId String
  professor   User           @relation("ProfessorQuizzes", fields: [professorId], references: [id])
  questions   QuizQuestion[]
  submissions Submission[]
}

// Tabela pivô para o relacionamento N:M entre Quiz e Question
model QuizQuestion {
  quizId     String
  questionId String
  quiz       Quiz     @relation(fields: [quizId], references: [id])
  question   Question @relation(fields: [questionId], references: [id])

  @@id([quizId, questionId])
}

model Submission {
  id        String   @id @default(uuid())
  answers   Json     // Ex: [{"questionId": "123", "answer": "Texto..."}]
  score     Float?   // Nota final, preenchida após a avaliação
  gradedAt  DateTime?
  createdAt DateTime @default(now())

  // Relacionamentos
  quizId    String
  quiz      Quiz     @relation(fields: [quizId], references: [id])
  alunoId   String
  aluno     User     @relation("AlunoSubmissions", fields: [alunoId], references: [id])
}